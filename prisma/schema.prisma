generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Employee {
  id           String         @id @default(cuid())
  firstName    String
  lastName     String
  jobTitle     String?
  agency       String?
  company      String?
  interventionTypeId String?
  interventionTypeRef InterventionType? @relation(fields: [interventionTypeId], references: [id], onDelete: SetNull)
  customerId   String?
  customer     Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerSiteId String?
  customerSite CustomerSite?  @relation(fields: [customerSiteId], references: [id], onDelete: SetNull)
  photoUrl     String?
  phoneAgency  String?
  interventionType String?
  vehiclePlate String?
  authorizedSite String?
  isActive     Boolean        @default(true)
  authorization Authorization?
  qrToken      QrToken?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String?
  address   String?
  phone     String?
  email     String?
  director  String?
  agencies  Agency[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agency {
  id        String   @id @default(cuid())
  name      String   @unique
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  siret     String?
  address   String?
  phone     String?
  email     String?
  director  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InterventionType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  employees   Employee[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String   @unique
  siret     String?
  address   String?
  postalCode String?
  city      String?
  activity  String?
  accessCodeEnabled Boolean @default(false)
  clientPortalEnabled Boolean @default(false)
  portalCanViewCodes Boolean @default(true)
  portalCanViewSites Boolean @default(true)
  portalCanViewScans Boolean @default(true)
  sites     CustomerSite[]
  accessCodes CustomerAccessCode[]
  employees Employee[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerSite {
  id        String   @id @default(cuid())
  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  postalCode String?
  city      String?
  codeRequired Boolean @default(false)
  isActive  Boolean @default(true)
  accessCodes CustomerAccessCode[]
  employees Employee[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, name])
}

model CustomerAccessCode {
  id        String   @id @default(cuid())
  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  siteId    String?
  site      CustomerSite? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  label     String
  codeHash  String
  codeLast4 String?
  scope     String   @default("site")
  isOneTime Boolean  @default(false)
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppUser {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String
  lastName  String
  role      String
  passwordHash String?
  mfaEnabled Boolean @default(false)
  mfaCodeHash String?
  company   String?
  agency    String?
  isActive  Boolean  @default(true)
  loginLogs LoginLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RolePermission {
  id        String   @id @default(cuid())
  role      String   @unique
  label     String
  dataScope String   @default("agency")
  canManageEmployees Boolean @default(false)
  canManageUsers Boolean @default(false)
  canManageSettings Boolean @default(false)
  canViewScans Boolean @default(true)
  canManageIncidents Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  user      AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Authorization {
  id         String   @id @default(cuid())
  employeeId String   @unique
  status     String
  validFrom  DateTime?
  validUntil DateTime?
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model QrToken {
  id         String   @id @default(cuid())
  employeeId String   @unique
  token      String   @unique
  isActive   Boolean  @default(true)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  issuedAt   DateTime @default(now())
  revokedAt  DateTime?
  expiresAt  DateTime?
}

model ScanLog {
  id        String   @id @default(cuid())
  token     String
  result    String
  company   String?
  latitude  Float?
  longitude Float?
  accuracy  Float?
  locationLabel String?
  locationSource String?
  locationCapturedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model IncidentReport {
  id          String   @id @default(cuid())
  token       String?
  reason      String
  description String?
  clientName  String?
  phone       String?
  email       String?
  status      String   @default("todo")
  adminComment String?
  treatedAt   DateTime?
  createdAt   DateTime @default(now())
}
